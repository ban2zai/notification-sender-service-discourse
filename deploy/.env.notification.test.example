# Copy to deploy/.env.notification.test.
# Fill on the server.

NOTIFICATION_BOT_TOKEN=replace-me-test-bot-token
NOTIFICATION_WEBHOOK_SECRET=replace-me-test-webhook-secret
NOTIFICATION_SUPABASE_SERVICE_KEY=replace-me-service-role-key

NOTIFICATION_SUPABASE_URL=http://supabase-kong:8000
NOTIFICATION_TELEGRAM_API_URL=http://telegram-bot-api:8081
NOTIFICATION_DISCOURSE_API_KEY=replace-me-discourse-api-key
NOTIFICATION_DISCOURSE_API_USERNAME=system

NOTIFICATION_DISCOURSE_LINKS_TABLE=replace-me-test-links-table
NOTIFICATION_DISCOURSE_BASE_URL=https://test-forum.example.com

NOTIFICATION_PORT=8067
NOTIFICATION_LOG_LEVEL=DEBUG
NOTIFICATION_LOG_PAYLOAD_DATA=false
NOTIFICATION_DISCOURSE_API_TIMEOUT_SECONDS=3
NOTIFICATION_DISCOURSE_TOPIC_CACHE_TTL_SECONDS=1800
NOTIFICATION_DISCOURSE_POST_CACHE_TTL_SECONDS=1800
NOTIFICATION_DISCOURSE_CATEGORIES_CACHE_TTL_SECONDS=43200
NOTIFICATION_TELEGRAM_EXCERPT_MAX_CHARS=400
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_TELEGRAM_GLOBAL_RATE_PER_SECOND=25
NOTIFICATION_TELEGRAM_CHAT_MIN_INTERVAL_SECONDS=1.05
