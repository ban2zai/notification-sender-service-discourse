# Скопируй в /var/tools/notification-sender-service-discourse/deploy/.env.notification.prod
# только когда тестовый контур полностью проверен. Не коммить реальные значения.

NOTIFICATION_BOT_TOKEN=replace-me-prod-bot-token
NOTIFICATION_WEBHOOK_SECRET=replace-me-prod-webhook-secret
NOTIFICATION_SUPABASE_SERVICE_KEY=replace-me-service-role-key

NOTIFICATION_SUPABASE_URL=http://supabase-kong:8000
NOTIFICATION_TELEGRAM_API_URL=http://telegram-bot-api:8081

NOTIFICATION_DISCOURSE_LINKS_TABLE=replace-me-prod-links-table
NOTIFICATION_DISCOURSE_BASE_URL=https://prod-forum.example.com

NOTIFICATION_PORT=18080
NOTIFICATION_LOG_LEVEL=INFO
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_TELEGRAM_GLOBAL_RATE_PER_SECOND=25
NOTIFICATION_TELEGRAM_CHAT_MIN_INTERVAL_SECONDS=1.05
